# General
font=Go Mono 12
background-color=#1A1A1A
text-color=#E0E0E0
border-color=#5c706e

# Border & layout
border-size=2
border-radius=0
padding=10
margin=10


# Width / placement
width=500
height=500
anchor=top-right

# Progress / indicators
progress-color=#3A3A3A

# Icons
icons=1
max-icon-size=32

# Default timeout
default-timeout=10000

# Grouping
group-by=none
max-visible=5

# Urgent notifications 
[urgency=high]
border-color=#ff5555
text-color=#ffffff
background-color=#1A1A1A
default-timeout=0

# Low priority
[urgency=low]
text-color=#a4ada9
