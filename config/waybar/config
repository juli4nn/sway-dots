{
  "layer": "top",
  "position": "top",
  "height": 24,

  "margin-top": 10,
  "margin-left": 200,
  "margin-right": 200,

  "spacing": 10,

  "modules-left": ["sway/workspaces"],
  "modules-center": ["sway/window"],
  "modules-right": ["tray", "memory", "clock"],

  "sway/workspaces": {
    "disable-scroll": false,
    "all-outputs": true,
    "format": "{name}",
    "format-icons": {
      "1": "one",
      "2": "two",
      "3": "three",
      "4": "four",
      "5": "five",
      "6": "six",
      "7": "seven",
      "8": "eight",
      "9": "nine",
      "10": "ten"
    }
  },

  "sway/window": {
    "format": "{title:.70}"
  },

  "tray": {
    "spacing": 6
  },

  "memory": {
   "format": "{used:0.1f}G",
   "interval": 3
  },


  "clock": {
    "interval": 1,
    "format": "{:%a %I:%M %p}",
    "format-alt": "{:%m/%d/%y %a %I:%M:%S %p}"
  }
}


